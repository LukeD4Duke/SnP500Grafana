      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_signal AS (    SELECT snapshot_date, drivers_json     FROM signal_snapshots     WHERE symbol = '${ticker}' AND timeframe = '${timeframe}'     ORDER BY snapshot_date DESC LIMIT 1) SELECT     latest_signal.snapshot_date,     COALESCE(driver.value->>'label', driver.value->>'metric', driver.value->>'name', 'driver') AS driver,     COALESCE(driver.value->>'state', '') AS state,     COALESCE(NULLIF(driver.value->>'score', ''), driver.value->>'value', '') AS score,     COALESCE(driver.value->>'detail', driver.value->>'explanation', '') AS detail FROM latest_signal CROSS JOIN LATERAL jsonb_array_elements(latest_signal.drivers_json) AS driver(value)",
          "refId": "A"
        }
      ],
      "title": "Key Drivers",
      "type": "table"
