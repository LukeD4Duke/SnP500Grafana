          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_snapshot AS (SELECT MAX(snapshot_date) AS snapshot_date FROM rank_snapshots WHERE timeframe = '${timeframe}'), latest_ranks AS (SELECT * FROM rank_snapshots WHERE timeframe = '${timeframe}' AND snapshot_date = (SELECT snapshot_date FROM latest_snapshot)) SELECT rs.symbol AS ticker, COALESCE(t.name, rs.symbol) AS company_name, COALESCE(t.sector,'') AS sector, rs.final_score, rs.bull_rank, rs.bear_rank, rs.regime_label, rs.recommendation_label, rs.score_change_1w, rs.score_change_1m FROM latest_ranks rs LEFT JOIN tickers t ON t.symbol = rs.symbol WHERE ('${sector}' = '__all' OR COALESCE(t.sector,'') = '${sector}') ORDER BY rs.bull_rank ASC, rs.symbol LIMIT 20",
          "refId": "A"
        }
      ],
