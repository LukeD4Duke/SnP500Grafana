          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest AS (\n    SELECT DISTINCT ON (si.indicator_key)\n        si.indicator_key,\n        COALESCE(ic.display_name, si.indicator_key) AS indicator_name,\n        COALESCE(ic.category, 'uncategorized') AS category,\n        si.timestamp,\n        si.value_numeric\n    FROM stock_indicators si\n    LEFT JOIN indicator_catalog ic ON ic.indicator_key = si.indicator_key\n    WHERE si.symbol = '${ticker}'\n    AND (${category:sqlstring} = '__all' OR ic.category IN (${category:sqlstring}))\n    ORDER BY si.indicator_key, si.timestamp DESC\n)\nSELECT indicator_key AS indicator, indicator_name, category, timestamp, value_numeric AS value\nFROM latest\nORDER BY category, indicator_name",
          "refId": "A"
        }
      ],
      "title": "Latest Indicator Snapshot",
      "type": "table"
