          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_snapshot AS (\n    SELECT MAX(snapshot_date) AS snapshot_date FROM signal_snapshots WHERE timeframe = '${timeframe}'\n)\nSELECT ss.symbol AS ticker, ss.volatility_risk_score AS score\nFROM signal_snapshots ss\nJOIN latest_snapshot ls ON ls.snapshot_date = ss.snapshot_date\nLEFT JOIN tickers t ON t.symbol = ss.symbol\nWHERE ss.timeframe = '${timeframe}' AND (${sector:sqlstring} = '__all' OR COALESCE(t.sector, '') = ${sector:sqlstring})\nORDER BY ss.volatility_risk_score DESC, ss.symbol\nLIMIT 20",
          "refId": "A"
        }
      ],
