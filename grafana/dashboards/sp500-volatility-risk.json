      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH latest_snapshot AS (\n    SELECT MAX(snapshot_date) AS snapshot_date FROM signal_snapshots WHERE timeframe = '${timeframe}'\n)\nSELECT ss.symbol AS ticker, COALESCE(t.name, ss.symbol) AS company_name, ss.volatility_risk_score, ss.risk_penalty, ss.volatility_state, ss.data_quality_flag, ss.final_score, ss.recommendation_label\nFROM signal_snapshots ss\nJOIN latest_snapshot ls ON ls.snapshot_date = ss.snapshot_date\nLEFT JOIN tickers t ON t.symbol = ss.symbol\nWHERE ss.timeframe = '${timeframe}' AND (${sector:sqlstring} = '__all' OR COALESCE(t.sector, '') = ${sector:sqlstring})\nORDER BY ss.volatility_risk_score DESC, ss.symbol\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Risk Table",
      "type": "table"
