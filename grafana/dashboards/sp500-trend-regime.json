          "rawSql": "WITH latest_snapshot AS (SELECT MAX(snapshot_date) AS snapshot_date FROM signal_snapshots WHERE timeframe = '${timeframe}'), latest_signals AS (SELECT * FROM signal_snapshots WHERE timeframe = '${timeframe}' AND snapshot_date = (SELECT snapshot_date FROM latest_snapshot)) SELECT ss.symbol AS ticker, COALESCE(t.name, ss.symbol) AS company_name, COALESCE(t.sector,'') AS sector, ss.close, ss.final_score, ss.trend_score, ss.momentum_score, ss.volume_score, ss.relative_strength_score, ss.structure_score, ss.mean_reversion_score, ss.volatility_risk_score, ss.regime_label, ss.recommendation_label, ss.breakout_flag, ss.breakdown_flag, ss.overbought_flag, ss.oversold_flag, ss.trend_alignment_flag, ss.data_quality_flag FROM latest_signals ss LEFT JOIN tickers t ON t.symbol = ss.symbol WHERE ('${sector}' = '__all' OR COALESCE(t.sector,'') = '${sector}') AND (TRUE) ORDER BY ss.trend_score DESC, ss.symbol LIMIT 20",
