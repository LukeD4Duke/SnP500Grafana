# S&P 500 Stock Analysis - Environment Variables
# Copy to .env and set values before deploying

# Database (required)
DB_PASSWORD=your_secure_password_here
DB_NAME=stocks
DB_USER=postgres

# Grafana (required)
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password

# Grafana host/port overrides
# Defaults keep Grafana on localhost:3001 for local development.
GRAFANA_BIND_IP=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_HOST=localhost
GRAFANA_ROOT_URL=http://localhost:3001

# Optional: Fetcher configuration
UPDATE_CRON=0 23 * * *
YFINANCE_CHUNK_SIZE=50
YFINANCE_DELAY_SEC=2.5
HISTORICAL_START=2020-01-01
BACKFILL_START=
