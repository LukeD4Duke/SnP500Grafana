# S&P 500 Stock Analysis - Environment Variables
# Copy to .env and set values before deploying

# Database (required)
DB_PASSWORD=your_secure_password_here
DB_NAME=stocks
DB_USER=postgres
DB_HOST=timescaledb
DB_PORT=5432

# Grafana (required)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password

# Grafana host/port overrides
# Defaults keep Grafana on localhost:3001 for local development.
GRAFANA_BIND_IP=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_HOST=localhost
GRAFANA_ROOT_URL=http://localhost:3001

# Manual report UI overrides
# The leaderboards dashboard links to this URL when launching a monthly export.
REPORT_UI_BIND_IP=127.0.0.1
REPORT_UI_PORT=3002
REPORT_UI_PUBLIC_URL=http://localhost:3002

# Optional: Fetcher configuration
UPDATE_CRON=0 23 * * *
YFINANCE_CHUNK_SIZE=50
YFINANCE_SYMBOL_RETRIES=2
YFINANCE_EMPTY_RESPONSE_RETRIES=0
YFINANCE_RECOVERY_CHUNK_SIZE=5
YFINANCE_FAILED_SYMBOL_LOG_LIMIT=20
YFINANCE_DELAY_SEC=2.5
YFINANCE_MAX_RETRIES=5
YFINANCE_RETRY_DELAY=60
HISTORICAL_START=2000-01-01
BACKFILL_START=
STARTUP_POST_SYNC_MODE=background
STARTUP_BACKFILL_MODE=background
FETCHER_STATUS_PORT=8080
INDICATORS_ENABLED=true
INDICATOR_INCREMENTAL_LOOKBACK_ROWS=1000
INDICATOR_REBUILD_ON_STARTUP=false
INDICATOR_BATCH_SIZE=25
ANALYTICS_ENABLED=true
ANALYTICS_TIMEFRAMES=daily,weekly,monthly
ANALYTICS_BACKFILL_BATCH_DATES=50
REPORTS_ENABLED=true
REPORT_OUTPUT_DIR=/app/reports
REPORT_WEEKLY_CRON=15 0 * * 1
REPORT_MONTHLY_CRON=30 0 1 * *
